# ---------------------------------------------------------------------------
# Kion environment copy tool — configuration
#
# This file describes ONE Kion install. The tool reads from / writes to the
# install named here.
#
# To copy an environment between installs:
#   1. cp .env.example .env.source   and fill in the SOURCE install + key
#   2. cp .env.example .env.target   and fill in the TARGET install + key
#   3. python kion_copy.py export --env-file .env.source
#   4. python kion_copy.py import --env-file .env.target          # dry-run preview
#   5. python kion_copy.py import --env-file .env.target --apply  # actually write
#
# (If you only use a single .env, just edit it between the export and import steps.)
# ---------------------------------------------------------------------------

# Base URL of the Kion install (no trailing /api — the tool adds it).
KION_URL=https://demo1.kion.io

# API bearer token. In Kion: User Profile -> App API Keys -> create a key.
# Used as:  Authorization: Bearer <KION_API_KEY>
KION_API_KEY=

# OPTIONAL. Fallback permission scheme id used on the TARGET install when a
# source entity's permission scheme cannot be matched by name. If left blank,
# entities whose scheme can't be resolved are skipped (import reports them).
DEFAULT_PERMISSION_SCHEME_ID=

# OPTIONAL. Set to "false" to skip TLS verification (self-signed certs). Default true.
KION_VERIFY_SSL=true

# OPTIONAL. API path prefix. Hosted installs serve the API under "/api" (default);
# a Kion app hit directly (e.g. http://localhost:8081) serves it at the root, so
# set this to empty:  KION_API_PREFIX=
KION_API_PREFIX=/api
